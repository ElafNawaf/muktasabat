SECRET_KEY=change-me-to-a-random-secret-key
DATABASE_URL=sqlite:///muktasbat.db
# DATABASE_URL=postgresql://muktasbat:password@localhost:5432/muktasbat
LOG_LEVEL=INFO
# Set to true to also print logs to stderr (Docker / terminal)
LOG_TO_CONSOLE=false
FLASK_ENV=development
TALISMAN_FORCE_HTTPS=false
SESSION_COOKIE_SECURE=false
BABEL_DEFAULT_LOCALE=ar
BABEL_DEFAULT_TIMEZONE=Asia/Riyadh

# Set to true to seed realistic mock data for POC demos
SEED_MOCK_DATA=false
