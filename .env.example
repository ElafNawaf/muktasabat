# FastAPI (api/)
SECRET_KEY=change-me-to-a-random-secret-key
# Local SQLite (default in api/config.py if unset):
DATABASE_URL=sqlite:///./muktasbat.db
# Docker / local Postgres:
# DATABASE_URL=postgresql://muktasbat:muktasbat_secret@127.0.0.1:5432/muktasbat

# Next.js (web/) — server-side calls to FastAPI
# API_URL=http://127.0.0.1:8000

# docker compose: host port for the web UI (default 3001 in compose; set WEB_PORT=3000 if nothing uses 3000).
# WEB_PORT=3000

# When true, forgot-password API may return debug_reset_url (local dev only; never in production)
# RESET_PASSWORD_DEBUG=true

# --- AWS SES (transactional email) — leave blank to log emails to stdout ---
# SES_REGION=us-east-1
# SES_FROM_EMAIL=no-reply@muktasabat.com
# SES_CONFIGURATION_SET=
# WEB_BASE_URL=https://muktasabat.com

# --- Amazon Translate (auto AR↔EN) — falls back to SES_REGION if unset ---
# TRANSLATE_REGION=us-east-1

# --- S3 image storage (building/unit photos). Leave blank to disable uploads. ---
# S3_BUCKET=muktasabat-uploads
# S3_REGION=us-east-1
# Optional: S3-compatible endpoint (Cloudflare R2, MinIO, etc.)
# S3_ENDPOINT_URL=
# Optional: public CDN URL for served objects; defaults to https://<bucket>.s3.<region>.amazonaws.com/<key>
# S3_PUBLIC_BASE_URL=https://cdn.muktasabat.com
